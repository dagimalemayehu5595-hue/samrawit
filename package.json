{
  "name": "samrawit-foundation-site",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://dagimalemayehu5595-hue.github.io/samrawit",
  "description": "Samrawit Foundation website built with React and Express",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon --ignore data/*.json --ignore data/**/*.json --ignore public/media/* --ignore public/media/**/* server.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server.js",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "keywords": [
    "charity",
    "react",
    "express"
  ],
  "author": "Samrawit Foundation",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "gh-pages": "^6.3.0",
    "nodemon": "^3.1.4",
    "vite": "^5.4.8"
  }
}
